struct Animal {
    int age = 0

    func speak() -> void {
        print("...\n")
    }

    init() {}
}

struct Dog : Animal {
    override func speak() -> void {
        print("Woof!\n")
    }

    init() {}
}

func main() -> int {
    Animal myAnimal = new Animal()
    myAnimal.speak()

    Dog myDog = new Animal()
    myDog.speak()
    myDog.age = myDog.age + 1
    print("%d\n", myDog.age)

    return 0
}