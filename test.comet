struct Foo {
    int abc

    init(int abc) {
        self.abc = abc
    }   

    func foo(int a) -> int {
        return self.abc + a
    }
}

struct OtherStruct : Foo {
    init(int abc) {
        super(self, abc)
    }
}

func sub(int a, int b) -> int {
    return a - b
}

func main() -> int {
    breakpoint
    OtherStruct test = new OtherStruct(123)
    return sub(5, 2)
}
