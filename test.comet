struct Foo {
    int abc

    init(int abc) {
        self.abc = abc
    }   

    func foo(int a) -> int {
        return self.abc + a
    }
}

struct OtherStruct : Foo {
    init(int abc) {
        super(self, abc)
    }

    func testFunc() -> int {
        return 24
    }
}

func main() -> int {
    OtherStruct test = new OtherStruct(3)
    return test.testFunc() + test.foo(3)
}
