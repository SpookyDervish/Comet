struct Test {
    int x
    int y
    int z

    init(int x, int y, int z) {
        self.x = x
        self.y = y
        self.z = z
    }

    func add(Test other) -> void {
        self.x += other.x
        self.y += other.y
        self.z += other.z
        return 0
    }
}

func main() -> int {
    mut int i = 0
    Test a = new Test(1, 4, 3)
    Test b = new Test(2, 1, 4)

    while (i < 10000000) {
        a.add(b)
        i += 1
    }

    return a.x + a.y + a.z
}