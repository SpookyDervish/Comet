import io

struct Exception {
    string type
    string message

    init(string type, string message) {
        self.type = type
        self.message = message
    }
}

func main() -> int {
    try {
        throw new Exception("Exception", "If you see this, we threw an exception!!")
    } except Exception {
        io.println("error: %s", e.message)
    }
    
    return 0
}