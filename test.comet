struct Foo {
    int abc

    init() {
        self.abc = 123
    }   

    func foo(int x) -> void {
        return x
    }
}

struct Bar : Foo {
    int xyz

    init() {
        super(self)
    }

    func testFunc(int x) -> void {
        return x
    }
}

func main() -> int {
    Bar test = new Bar()
    int x = test.testFunc(2)

    Foo test2 = new Foo()
    int y = test.foo(4)

    return x + y
}