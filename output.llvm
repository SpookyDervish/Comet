; ModuleID = 'main'
source_filename = "main"

define i8 @add(i8 %0, i8 %1) {
add_entry:
  %a = alloca i8, align 1
  store i8 %0, ptr %a, align 1
  %b = alloca i8, align 1
  store i8 %1, ptr %b, align 1
  %a1 = load i8, ptr %a, align 1
  %b2 = load i8, ptr %b, align 1
  %tmp = add i8 %a1, %b2
  ret i8 %tmp
}

define i8 @main() {
main_entry:
  %add = call i8 @add(i8 2, i8 5)
  ret i8 %add
}
