; ModuleID = 'main'
source_filename = "main"

@str = private constant [8 x i8] c"x = %d\0A\00"

declare i32 @printf(ptr, ...)

define i32 @main() {
main_entry:
  %x = alloca i32, align 4
  store i32 123, ptr %x, align 4
  %x1 = load i32, ptr %x, align 4
  %print = call i32 (ptr, ...) @printf(ptr @str, i32 %x1)
  ret i32 0
}
