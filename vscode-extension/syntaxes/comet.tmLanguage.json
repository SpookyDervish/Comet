{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Comet",
	"patterns": [
        {
            "include": "#comments"
        },
		{
			"include": "#keywords"
		},
        {
            "include": "#functions"
        },
        {
            "include": "#types"
        },
        {
            "include": "#operators"
        },
		{
			"include": "#strings"
		},
        {
            "include": "#numbers"
        }
	],
	"repository": {
        "comments": {
			"patterns": [
                {
					"name": "comment.block.comet",
					"begin": "--\\[\\[",
					"end": "\\]\\]"
				},
				{
					"name": "comment.line.double-slash.comet",
					"begin": "--",
					"end": "$"
				}
            ]
		},

		"keywords": {
			"patterns": [{
				"name": "keyword.control.comet",
				"match": "\\b(if|self|while|for|return|import|func|struct|mut|private|protected|readonly|override|init|in|new|can|enum|step|else|break|continue|breakpoint|try|except|throw)\\b"
			}]
		},

        "functions": {
            "patterns": [
                {
					"comment": "Function definition: func myFunc(",
					"match": "\\b(func)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b\\s*(?=\\()",
					"captures": {
						"1": { "name": "keyword.control.comet" },
						"2": { "name": "entity.name.function.comet" }
					}
				},
				{
					"comment": "Function call: myFunc(",
					"match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b\\s*(?=\\()",
					"captures": {
						"1": { "name": "entity.name.function.comet" }
					}
				}
            ]
        },

        "types": {
            "patterns": [
                {
                    "name": "support.type.primitive.comet",
                    "match": "\\b(small|int|big|float|double|bool|void|string)\\b"
                },
                {
					"name": "storage.type.comet",
					"match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
				}
            ]
        },

        "operators": {
            "patterns": [{
                "name": "keyword.operator.comet",
                "match": "\\+=|-=|\\*=|/=|\\+\\+|--|\\.\\.|\\+|-|\\*|/|=|==|!=|<=|>=|<|>|\\.|->|\\:|\\#"
            }]
        },

		"strings": {
			"name": "string.quoted.double.comet",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.comet",
					"match": "\\\\."
				},
                {
					"name": "constant.other.placeholder.comet",
					"match": "%[a-zA-Z]"
				}
			]
		},

        "numbers": {
            "patterns": [
                {
					"name": "constant.numeric.float.comet",
					"match": "\\b[0-9]+\\.[0-9]+\\b"
				},
				{
					"name": "constant.numeric.integer.comet",
					"match": "\\b[0-9]+\\b"
				}
            ]
        }
	},
	"scopeName": "source.comet"
}