{
  "name": "comet",
  "displayName": "Comet",
  "description": "Syntax highlighting for the Comet Programming Language",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [{
      "id": "comet",
      "aliases": ["Comet", "comet"],
      "extensions": [".comet"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "comet",
      "scopeName": "source.comet",
      "path": "./syntaxes/comet.tmLanguage.json"
    }]
  }
}
